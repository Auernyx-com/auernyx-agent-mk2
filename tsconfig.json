{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true
  },
  "include": [
    "core/**/*",
    "capabilities/**/*",
    "clients/**/*"
  ],
  "exclude": ["node_modules", "dist", "logs", "artifacts", "**/*.test.ts"]
}
